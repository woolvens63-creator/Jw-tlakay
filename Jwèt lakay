<!DOCTYPE html>
<html>
<head>
  <title>Jwèt Lakay</title>
  <style>
    body { text-align:center; font-family:Arial; background:#111; color:#fff; }
    h1 { margin-top:20px; }
    .board {
      display:grid;
      grid-template-columns:repeat(3,100px);
      gap:5px;
      justify-content:center;
      margin-top:20px;
    }
    .cell {
      width:100px; height:100px;
      font-size:30px;
      cursor:pointer;
      background:#222;
      color:#fff;
      border:none;
    }
    .cell:hover { background:#333; }
  </style>
</head>
<body>

<h1>Mòpyon Lakay 🎮</h1>
<p id="status">Jwè X ap jwe</p>

<div class="board" id="board"></div>

<script>
let board = ["","","","","","","","",""];
let player = "X";

function render(){
  const b = document.getElementById("board");
  b.innerHTML = "";
  board.forEach((cell,i)=>{
    let btn = document.createElement("button");
    btn.className = "cell";
    btn.innerText = cell;
    btn.onclick = ()=>play(i);
    b.appendChild(btn);
  });
}

function play(i){
  if(board[i] === ""){
    board[i] = player;
    if(checkWin()){
      document.getElementById("status").innerText = "Jwè " + player + " genyen!";
      return;
    }
    player = player === "X" ? "O" : "X";
    document.getElementById("status").innerText = "Jwè " + player + " ap jwe";
    render();
  }
}

function checkWin(){
  const wins = [
    [0,1,2],[3,4,5],[6,7,8],
    [0,3,6],[1,4,7],[2,5,8],
    [0,4,8],[2,4,6]
  ];
  return wins.some(c =>
    board[c[0]] &&
    board[c[0]] === board[c[1]] &&
    board[c[1]] === board[c[2]]
  );
}

render();
</script>

</body>
</html>
